# =============================================================================
# Enterprise Harness — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your API keys:
#     cp .env.example .env
#
# Then run:
#     python main.py
#
# NEVER commit .env to version control.
# =============================================================================

# --- Anthropic (required for default config) --------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- OpenAI (required for gpt-4o route) ------------------------------------
OPENAI_API_KEY=sk-xxxxx

# --- DeepSeek (optional, OpenAI-compatible) ---------------------------------
# Free/cheap alternative. Get key at: https://platform.deepseek.com
# DEEPSEEK_API_KEY=sk-xxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Zhipu/GLM (optional, OpenAI-compatible) --------------------------------
# Get key at: https://open.bigmodel.cn
# ZHIPU_API_KEY=xxxxx
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- Moonshot/Kimi (optional, OpenAI-compatible) ----------------------------
# Get key at: https://platform.moonshot.cn
# MOONSHOT_API_KEY=sk-xxxxx
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- Custom OpenAI-compatible endpoint (optional) ---------------------------
# Any provider with an OpenAI-compatible API (vLLM, Ollama, LiteLLM, etc.)
# CUSTOM_API_KEY=xxxxx
# CUSTOM_BASE_URL=http://localhost:8000/v1
