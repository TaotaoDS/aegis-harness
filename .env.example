# =============================================================================
# Enterprise Harness — Environment Variables Template
# =============================================================================
# 使用方法:
#   cp .env.example .env
#   填入你的真实 API Key，然后运行:
#   python main.py
#
# 安全规则:
#   - NEVER 将 .env 提交到版本控制（已在 .gitignore 中排除）
#   - .env.example 只含占位符，可以安全提交
#   - models_config.yaml 中的 ${VAR} 会在启动时自动被此文件中的值替换
# =============================================================================


# --- Anthropic (Claude 系列) --------------------------------------------------
# 申请: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx


# --- OpenAI (GPT 系列) ---------------------------------------------------------
# 申请: https://platform.openai.com
OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1    # 如需代理，取消注释并修改


# --- NVIDIA NIM (Llama / Mistral / Mixtral 等开源模型) -------------------------
# 免费额度 1000 次调用，支持数百个开源模型推理端点
# 申请: https://build.nvidia.com
#
# models_config.yaml 中用法示例 (Pattern B — 内联插值):
#   api_key: ${NVIDIA_API_KEY}
#   base_url: https://integrate.api.nvidia.com/v1
#
# NVIDIA_API_KEY=nvapi-xxxxx
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1


# --- DeepSeek (DeepSeek-V3 / R1) ----------------------------------------------
# 价格极低，推理能力强，OpenAI 兼容协议
# 申请: https://platform.deepseek.com
#
# DEEPSEEK_API_KEY=sk-xxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1


# --- 智谱 GLM (GLM-4 / GLM-5 系列) -------------------------------------------
# 中文能力优秀，有免费额度
# 申请: https://open.bigmodel.cn
#
# ZHIPU_API_KEY=xxxxx.xxxxxx
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4


# --- Moonshot / Kimi (长上下文 128k/1M) ----------------------------------------
# 超长上下文处理能力突出
# 申请: https://platform.moonshot.cn
#
# MOONSHOT_API_KEY=sk-xxxxx
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1


# --- 本地 / 自部署 (Ollama / vLLM / LiteLLM) ----------------------------------
# 无需 API Key，Ollama 默认 Key 填任意非空值即可
#
# LOCAL_API_KEY=ollama
# LOCAL_BASE_URL=http://localhost:11434/v1
