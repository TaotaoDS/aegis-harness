# =============================================================================
# AegisHarness — Environment Variables Template
# =============================================================================
# Usage:
#   cp .env.example .env
#   Fill in your real API keys, then run:
#   python main.py
#
# Security rules:
#   - NEVER commit .env to version control (already excluded in .gitignore)
#   - .env.example contains only placeholders and is safe to commit
#   - ${VAR} references in models_config.yaml are automatically substituted
#     with values from this file at startup
# =============================================================================


# --- OpenRouter (one key unlocks 300+ models: Claude / GPT / Gemini / Llama / DeepSeek, etc.) ----
# Get a key: https://openrouter.ai/settings/keys  (free tier, no credit card required)
# Highly recommended: a single key drives all major models — no need to register
# separately with each provider
#
# OPENROUTER_API_KEY=sk-or-xxxxx


# --- Anthropic (Claude models) -----------------------------------------------
# Get a key: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxx


# --- OpenAI (GPT models) -------------------------------------------------------
# Get a key: https://platform.openai.com
OPENAI_API_KEY=sk-xxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1    # uncomment and change to use a proxy


# --- NVIDIA NIM (Llama / Mistral / Mixtral and other open-source models) -------
# Free tier: 1,000 inference calls; supports hundreds of open-source model endpoints
# Get a key: https://build.nvidia.com
#
# Usage example in models_config.yaml (Pattern B — inline interpolation):
#   api_key: ${NVIDIA_API_KEY}
#   base_url: https://integrate.api.nvidia.com/v1
#
# NVIDIA_API_KEY=nvapi-xxxxx
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1


# --- DeepSeek (DeepSeek-V3 / R1) ----------------------------------------------
# Very low cost, strong reasoning, OpenAI-compatible API
# Get a key: https://platform.deepseek.com
#
# DEEPSEEK_API_KEY=sk-xxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1


# --- Zhipu GLM (GLM-4 / GLM-5 series) ----------------------------------------
# Excellent Chinese-language capability, free tier available
# Get a key: https://open.bigmodel.cn
#
# ZHIPU_API_KEY=xxxxx.xxxxxx
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4


# --- Moonshot / Kimi (long-context 128k / 1M) ----------------------------------
# Outstanding ultra-long context processing capability
# Get a key: https://platform.moonshot.cn
#
# MOONSHOT_API_KEY=sk-xxxxx
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1


# --- Local / self-hosted (Ollama / vLLM / LiteLLM) ----------------------------
# No API key required; for Ollama the default key can be any non-empty value
#
# LOCAL_API_KEY=ollama
# LOCAL_BASE_URL=http://localhost:11434/v1
