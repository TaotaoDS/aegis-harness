# =============================================================================
# AegisHarness — Docker environment template
# =============================================================================
# Usage:
#   cp .env.docker .env
#   Fill in your real API keys, then run:
#   docker compose up --build
#
# Do NOT commit .env to version control.
# This template (.env.docker) is safe to commit.
# =============================================================================

# --- Auth / JWT ---------------------------------------------------------------
# Required: enables register/login endpoints. Generate with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-64-char-hex-string

# --- PostgreSQL (docker-compose internal) ------------------------------------
# Defaults shown; change for production deployments
POSTGRES_USER=harness
POSTGRES_PASSWORD=harness_secret_change_me_in_production
POSTGRES_DB=harness
# POSTGRES_PORT=5432    # host-side port binding (default 5432)

# --- Service ports (optional overrides) --------------------------------------
# BACKEND_PORT=8000
# FRONTEND_PORT=3000

# --- LLM API Keys ------------------------------------------------------------
# Fill in at least one provider.

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# OpenAI (GPT)
# OPENAI_API_KEY=sk-xxxxx

# NVIDIA NIM (Llama / Mixtral / GLM — 1000 free calls)
# NVIDIA_API_KEY=nvapi-xxxxx
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# DeepSeek
# DEEPSEEK_API_KEY=sk-xxxxx
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Zhipu GLM
# ZHIPU_API_KEY=xxxxx.xxxxxx
# ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Moonshot / Kimi
# MOONSHOT_API_KEY=sk-xxxxx
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
